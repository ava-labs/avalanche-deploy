# Azure Terraform Configuration
# Copy to terraform.tfvars and customize

# Azure region
location = "East US"

# Resource naming
name_prefix = "avalanche-l1"
environment = "fuji" # or "mainnet"

# Network
vnet_cidr   = "10.0.0.0/16"
subnet_cidr = "10.0.1.0/24"

# Operator IP (leave empty to auto-detect, or specify e.g., "1.2.3.4/32")
operator_ip = ""

# Node counts
validator_count = 3
rpc_count       = 2

# VM sizes - using Lsv3 series for LOCAL NVMe storage
#
# IMPORTANT: Lsv3 series = local NVMe SSDs (fast, ephemeral)
#            Dsv5 series = managed disks only (network-attached, slower)
#
# Testing/Fuji (smaller, cost-effective):
#   Validators: Standard_L8s_v3 (8 vCPU, 64GB, 1x800GB NVMe) - smallest Lsv3
#   RPC: Standard_L8s_v3 (8 vCPU, 64GB, 1x800GB NVMe)
#   Note: Lsv3 starts at 8 vCPU, no smaller option with local NVMe
#
# Alternative without local NVMe (cheaper but slower):
#   Validators: Standard_D4s_v5 (4 vCPU, 16GB) + Premium SSD
#   RPC: Standard_D2s_v5 (2 vCPU, 8GB) + Premium SSD
#
validator_vm_size = "Standard_L8s_v3"   # 8 vCPU, 64GB, 1x800GB NVMe
rpc_vm_size       = "Standard_L8s_v3"   # 8 vCPU, 64GB, 1x800GB NVMe

# Disk configuration (OS disk - data goes on local NVMe for Lsv3)
disk_size_gb = 100 # GB

# SSH configuration
admin_username = "azureuser"
ssh_public_key = "ssh-rsa AAAA..." # Your public key content

# Access control
enable_public_rpc     = false
enable_public_grafana = true
