# GCP Terraform Configuration
# Copy to terraform.tfvars and customize

# GCP project
project_id = "your-project-id"

# Region and zones
region = "us-central1"
zones  = ["us-central1-a", "us-central1-b", "us-central1-c"]

# Resource naming
name_prefix = "avalanche-l1"
environment = "fuji" # or "mainnet"

# Network
subnet_cidr = "10.0.0.0/24"

# Operator IP (leave empty to auto-detect, or specify e.g., "1.2.3.4/32")
operator_ip = ""

# Node counts
validator_count = 2
rpc_count       = 1

# Machine types
#
# IMPORTANT: GCP local SSDs must be attached separately (375GB each)
#            Set local_ssd_count > 0 to attach NVMe local SSDs
#
# Testing/Fuji (smaller, cost-effective):
#   Validators: n2-standard-4 (4 vCPU, 16GB) + 1 local SSD
#   RPC: n2-standard-2 (2 vCPU, 8GB) + 1 local SSD
#
# Production/Mainnet:
#   Validators: n2-standard-8 (8 vCPU, 32GB) + 1-2 local SSDs
#   RPC: n2-standard-4 (4 vCPU, 16GB) + 1 local SSD
#
validator_machine_type = "n2-standard-4"  # 4 vCPU, 16GB - good for testing
rpc_machine_type       = "n2-standard-2"  # 2 vCPU, 8GB - good for testing

# Disk configuration
disk_size_gb    = 100  # GB - boot disk only, data on local SSD
local_ssd_count = 1    # Number of 375GB local NVMe SSDs to attach

# SSH configuration
ssh_user       = "ubuntu"
ssh_public_key = "" # Content of your public key

# Access control
enable_public_rpc        = false
enable_public_grafana    = true
enable_public_blockscout = true
