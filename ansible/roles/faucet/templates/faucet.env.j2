# Faucet runtime secrets - rendered by ansible, mode 0600, do not commit.
# The app reads ONLY these from the environment; all chain configuration is
# baked into the image at build time from config.json.

# Faucet wallet private key (must be funded on the L1)
PK={{ faucet_private_key }}

# reCAPTCHA secrets. 'DISABLED' activates the captcha bypass patch for
# private/internal faucets (see role defaults before exposing publicly).
CAPTCHA_SECRET={{ 'DISABLED' if (faucet_disable_captcha | bool) else faucet_captcha_secret }}
V2_CAPTCHA_SECRET={{ 'DISABLED' if (faucet_disable_captcha | bool) else faucet_captcha_v2_secret }}
