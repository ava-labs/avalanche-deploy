version: '3.8'

services:
  faucet:
    image: {{ faucet_image | default('avaplatform/faucet') }}:{{ faucet_image_tag | default('latest') }}
    container_name: avalanche-faucet
    restart: unless-stopped
    ports:
      - "{{ faucet_port | default(8010) }}:8000"
    environment:
      - RPC_URL=http://{{ faucet_rpc_host | default(ansible_host) }}:9650/ext/bc/{{ faucet_chain_id }}/rpc
      - CHAIN_ID={{ faucet_evm_chain_id }}
      - DROP_SIZE={{ faucet_amount | default(1) }}
      - RATE_LIMIT={{ faucet_rate_limit | default(1) }}
    env_file:
      - .env
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
