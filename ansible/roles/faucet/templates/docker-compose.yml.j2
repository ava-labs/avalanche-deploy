services:
  faucet:
    # Built locally from the pinned upstream source by this role - no public
    # image exists for the Avalanche faucet. Chain config is baked into the
    # image at build time; only PK/CAPTCHA secrets come from .env.
    image: {{ faucet_image }}:{{ faucet_image_tag }}
    container_name: avalanche-faucet
    restart: unless-stopped
    ports:
      - "{{ faucet_port }}:8000"
    env_file:
      - .env
    extra_hosts:
      - "host.docker.internal:host-gateway"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
