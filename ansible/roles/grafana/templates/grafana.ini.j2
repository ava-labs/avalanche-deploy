[server]
http_port = {{ grafana_port }}
http_addr = 0.0.0.0

[paths]
data = {{ grafana_data_dir }}
logs = {{ grafana_data_dir }}/log
plugins = {{ grafana_data_dir }}/plugins
provisioning = {{ grafana_config_dir }}/provisioning

[security]
admin_user = {{ grafana_admin_user }}
admin_password = {{ grafana_admin_password }}

[auth.anonymous]
enabled = {{ grafana_anonymous_enabled | lower }}
org_role = Viewer

[users]
allow_sign_up = false

[dashboards]
default_home_dashboard_path = {{ grafana_data_dir }}/dashboards/avalanche-l1.json
