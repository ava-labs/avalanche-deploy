global:
  scrape_interval: {{ scrape_interval }}
  evaluation_interval: {{ evaluation_interval }}

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{ prometheus_port }}']

  # Avalanche metrics (port 9650)
  - job_name: 'avalanche-validators'
    metrics_path: '/ext/metrics'
    static_configs:
      - targets:
{% for host in groups['validators'] %}
          - '{{ hostvars[host]['private_ip'] | default(hostvars[host]['ansible_host']) }}:9650'
{% endfor %}

  - job_name: 'avalanche-rpc'
    metrics_path: '/ext/metrics'
    static_configs:
      - targets:
{% for host in groups['rpc'] %}
          - '{{ hostvars[host]['private_ip'] | default(hostvars[host]['ansible_host']) }}:9650'
{% endfor %}

  # Node exporter system metrics (port 9100)
  - job_name: 'node-validators'
    static_configs:
      - targets:
{% for host in groups['validators'] %}
          - '{{ hostvars[host]['private_ip'] | default(hostvars[host]['ansible_host']) }}:9100'
{% endfor %}

  - job_name: 'node-rpc'
    static_configs:
      - targets:
{% for host in groups['rpc'] %}
          - '{{ hostvars[host]['private_ip'] | default(hostvars[host]['ansible_host']) }}:9100'
{% endfor %}
