global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{ prometheus_port }}']

  # Avalanche metrics (port 9650) - job name matches dashboard expectations
  - job_name: 'avalanchego'
    metrics_path: '/ext/metrics'
    static_configs:
      - targets:
{% for host in groups['validators'] %}
          - '{{ hostvars[host]['private_ip'] | default(hostvars[host]['ansible_host']) }}:9650'
{% endfor %}
{% for host in groups['rpc'] %}
          - '{{ hostvars[host]['private_ip'] | default(hostvars[host]['ansible_host']) }}:9650'
{% endfor %}

  # Node exporter system metrics (port 9100) - job name matches dashboard expectations
  - job_name: 'node'
    static_configs:
      - targets:
{% for host in groups['validators'] %}
          - '{{ hostvars[host]['private_ip'] | default(hostvars[host]['ansible_host']) }}:9100'
{% endfor %}
{% for host in groups['rpc'] %}
          - '{{ hostvars[host]['private_ip'] | default(hostvars[host]['ansible_host']) }}:9100'
{% endfor %}
