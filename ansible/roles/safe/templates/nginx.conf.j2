# Safe Multisig Nginx Configuration
# Generated by Ansible for chain {{ evm_chain_id }}

upstream safe-ui {
    server 127.0.0.1:{{ safe_ui_port }};
}

upstream safe-cgw {
    server 127.0.0.1:{{ safe_cgw_port }};
}

upstream safe-txs {
    server 127.0.0.1:{{ safe_txs_port }};
}

upstream safe-cfg {
    server 127.0.0.1:{{ safe_cfg_port }};
}

upstream avalanche-rpc {
    server 127.0.0.1:9650;
}

upstream blockscout {
    server 127.0.0.1:4001;
}

# HTTP -> HTTPS redirect
server {
    listen {{ safe_http_port }};
    server_name {{ safe_domain if safe_domain else '_' }};
    return 301 https://$host$request_uri;
}

# HTTPS server (required for wallet connection - Web Crypto API needs secure context)
server {
    listen 443 ssl;
    server_name {{ safe_domain if safe_domain else '_' }};

    # SSL certificate (self-signed, generated during deployment)
    ssl_certificate /etc/nginx/ssl/safe.crt;
    ssl_certificate_key /etc/nginx/ssl/safe.key;

    # SSL settings
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    # Security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # URL rewriting for HTTPS compatibility
    # The Safe UI has gateway URLs baked into the JS at build time.
    # We use sub_filter to rewrite HTTP URLs to relative /cgw path to avoid mixed content blocking.
    sub_filter_once off;
    sub_filter_types application/javascript;
    sub_filter 'http://{{ ansible_host }}:{{ safe_cgw_port }}' '/cgw';

    # Logging
    access_log /var/log/nginx/safe_access.log;
    error_log /var/log/nginx/safe_error.log;

    # Max upload size
    client_max_body_size 10M;

    # Bridge: Safe UI calls old CGW estimation endpoint, proxy directly to TXS
    # CGW v1.80+ removed this endpoint; the old UI still calls it for gas estimation
    location ~ ^/cgw/v1/chains/[0-9]+/safes/(0x[a-fA-F0-9]+)/multisig-transactions/estimations$ {
        rewrite ^/cgw/v1/chains/[0-9]+/safes/(0x[a-fA-F0-9]+)/multisig-transactions/estimations$ /api/v1/safes/$1/multisig-transactions/estimations/ break;
        proxy_pass http://safe-txs;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Client Gateway API
    # Some Safe UI endpoints don't include chain ID - rewrite them to include our chain
    location /cgw/ {
        # Rewrite endpoints that don't include chain ID to include it
        rewrite ^/cgw/v1/owners/(.*)/safes$ /v1/chains/{{ evm_chain_id }}/owners/$1/safes break;
        rewrite ^/cgw/v1/safes/(0x[a-fA-F0-9]+)$ /v1/chains/{{ evm_chain_id }}/safes/$1 break;
        rewrite ^/cgw/v1/safes/(0x[a-fA-F0-9]+)/(.*)$ /v1/chains/{{ evm_chain_id }}/safes/$1/$2 break;
        # Default rewrite for all other cgw paths
        rewrite ^/cgw/(.*) /$1 break;

        proxy_pass http://safe-cgw;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Transaction Service API
    location /txs/ {
        rewrite ^/txs/(.*) /$1 break;
        proxy_pass http://safe-txs;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Config Service API
    location /cfg/ {
        rewrite ^/cfg/(.*) /$1 break;
        proxy_pass http://safe-cfg;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Health check endpoint
    location /health {
        return 200 'OK';
        add_header Content-Type text/plain;
    }

    # RPC proxy for HTTPS (avoids mixed content blocking)
    location /rpc {
        proxy_pass http://avalanche-rpc/ext/bc/{{ chain_id }}/rpc;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Content-Type application/json;
    }

    # Web UI (default)
    location / {
        proxy_pass http://safe-ui;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Disable compression to allow sub_filter to work
        proxy_set_header Accept-Encoding "";

        # Prevent browser caching of HTML (ensures config/chain changes take effect)
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        add_header Pragma "no-cache" always;

        # Next.js hot reload support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

# Blockscout Block Explorer (HTTPS on port 4443)
# Served on a separate port because both Safe UI and Blockscout are Next.js apps
# that use /_next/ for assets — they cannot share the same hostname/root path.
server {
    listen 4443 ssl;
    server_name {{ safe_domain if safe_domain else '_' }};

    ssl_certificate /etc/nginx/ssl/safe.crt;
    ssl_certificate_key /etc/nginx/ssl/safe.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    location / {
        proxy_pass http://blockscout;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Blockscout backend API
    location /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
