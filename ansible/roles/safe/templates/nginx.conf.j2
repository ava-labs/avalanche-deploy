# Safe Multisig Nginx Configuration
# Generated by Ansible for chain {{ evm_chain_id }}

upstream safe-ui {
    server 127.0.0.1:{{ safe_ui_port }};
}

upstream safe-cgw {
    server 127.0.0.1:{{ safe_cgw_port }};
}

upstream safe-txs {
    server 127.0.0.1:{{ safe_txs_port }};
}

upstream safe-cfg {
    server 127.0.0.1:{{ safe_cfg_port }};
}

server {
    listen {{ safe_http_port }};
    server_name _;

    # Logging
    access_log /var/log/nginx/safe_access.log;
    error_log /var/log/nginx/safe_error.log;

    # Max upload size
    client_max_body_size 10M;

    # Client Gateway API
    location /cgw/ {
        rewrite ^/cgw/(.*) /$1 break;
        proxy_pass http://safe-cgw;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Transaction Service API
    location /txs/ {
        rewrite ^/txs/(.*) /$1 break;
        proxy_pass http://safe-txs;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Config Service API
    location /cfg/ {
        rewrite ^/cfg/(.*) /$1 break;
        proxy_pass http://safe-cfg;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Health check endpoint
    location /health {
        return 200 'OK';
        add_header Content-Type text/plain;
    }

    # Web UI (default)
    location / {
        proxy_pass http://safe-ui;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Next.js hot reload support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
