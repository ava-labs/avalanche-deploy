# Safe Wallet Web UI Configuration
# Generated by Ansible for chain {{ evm_chain_id }}

# Gateway URL - use nginx proxy path for HTTPS compatibility (avoids mixed content blocking)
# The /cgw/ path is proxied to the CGW service by nginx
NEXT_PUBLIC_GATEWAY_URL_PRODUCTION=/cgw
NEXT_PUBLIC_GATEWAY_URL_STAGING=/cgw

# Safe apps
NEXT_PUBLIC_SAFE_APPS_INFURA_TOKEN=

# WalletConnect
NEXT_PUBLIC_WC_PROJECT_ID=

# Features
NEXT_PUBLIC_IS_PRODUCTION=true

# Chain configuration
NEXT_PUBLIC_TENDERLY_ORG_NAME=
NEXT_PUBLIC_TENDERLY_PROJECT_NAME=
NEXT_PUBLIC_TENDERLY_SIMULATE_ENDPOINT_URL=

# Analytics (disabled)
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_AUTH=
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_DEVELOPMENT_AUTH=

# Contract addresses for custom chain (bypasses safe-deployments package)
# This allows Safe UI to work with any EVM chain without requiring PRs to safe-deployments
NEXT_PUBLIC_SAFE_VERSION=1.4.1
# RPC uses /rpc proxy path to avoid mixed content (nginx proxies to avalanchego)
# Block explorer uses /explorer proxy path (nginx proxies to Blockscout on 4001)
{% set safe_host = safe_domain if safe_domain else ansible_host %}
NEXT_PUBLIC_CHAIN_CONFIGS={"{{ evm_chain_id }}":{"chainId":"{{ evm_chain_id }}","chainName":"{{ chain_name }}","shortName":"{{ chain_short_name }}","rpcUri":{"value":"https://{{ safe_host }}/rpc"},"nativeCurrency":{"name":"{{ native_currency_name }}","symbol":"{{ native_currency_symbol }}","decimals":{{ native_currency_decimals }}},"blockExplorerUriTemplate":{"address":"https://{{ safe_host }}/explorer/address/{{ '{{address}}' }}","txHash":"https://{{ safe_host }}/explorer/tx/{{ '{{txHash}}' }}"}}}
