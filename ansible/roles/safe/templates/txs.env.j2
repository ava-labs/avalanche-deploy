# Safe Transaction Service Configuration
# Generated by Ansible for chain {{ evm_chain_id }}

# Django settings
SECRET_KEY={{ safe_txs_secret_key }}
DEBUG=0
ROOT_LOG_LEVEL=INFO
DJANGO_ALLOWED_HOSTS=*
{% set safe_host = safe_domain if safe_domain else ansible_host %}
CSRF_TRUSTED_ORIGINS=https://{{ safe_host }},https://{{ ansible_host }},http://{{ ansible_host }}:{{ safe_http_port }},http://localhost:{{ safe_http_port }}

# Database
DATABASE_URL=postgres://{{ safe_db_user }}:{{ safe_db_password }}@postgres-txs:5432/{{ safe_txs_db_name }}

# Redis
REDIS_URL={{ safe_redis_url }}

# Celery
CELERY_BROKER_URL=amqp://{{ safe_rabbitmq_user }}:{{ safe_rabbitmq_password }}@rabbitmq:5672//

# Ethereum node (Avalanche L1 RPC)
ETHEREUM_NODE_URL={{ safe_rpc_url }}
ETHEREUM_TRACING_NODE_URL={{ safe_rpc_url }}

# Chain configuration
ETH_L2_NETWORK={{ '1' if safe_use_l2 else '0' }}
CHAIN_ID={{ evm_chain_id }}

# Worker configuration (required for celery workers)
WORKER_QUEUES=default,indexing,contracts,tokens,notifications,webhooks

# Safe contracts (v1.4.1 canonical addresses)
SAFE_CONTRACT_ADDRESS={{ safe_contracts.safe_singleton }}
SAFE_V1_4_1_CONTRACT_ADDRESS={{ safe_contracts.safe_singleton }}
SAFE_L2_CONTRACT_ADDRESS={{ safe_contracts.safe_singleton }}
SAFE_L2_V1_4_1_CONTRACT_ADDRESS={{ safe_contracts.safe_singleton }}
DEFAULT_SAFE_CONTRACT_ADDRESS={{ safe_contracts.safe_singleton }}
PROXY_FACTORY_CONTRACT_ADDRESS={{ safe_contracts.proxy_factory }}
PROXY_FACTORY_V1_4_1_CONTRACT_ADDRESS={{ safe_contracts.proxy_factory }}
MULTI_SEND_CONTRACT_ADDRESS={{ safe_contracts.multi_send }}
MULTI_SEND_V1_4_1_CONTRACT_ADDRESS={{ safe_contracts.multi_send }}
MULTI_SEND_CALL_ONLY_CONTRACT_ADDRESS={{ safe_contracts.multi_send_call_only }}
MULTI_SEND_CALL_ONLY_V1_4_1_CONTRACT_ADDRESS={{ safe_contracts.multi_send_call_only }}
FALLBACK_HANDLER_CONTRACT_ADDRESS={{ safe_contracts.fallback_handler }}
FALLBACK_HANDLER_V1_4_1_CONTRACT_ADDRESS={{ safe_contracts.fallback_handler }}
CREATE_CALL_CONTRACT_ADDRESS={{ safe_contracts.create_call }}
CREATE_CALL_V1_4_1_CONTRACT_ADDRESS={{ safe_contracts.create_call }}
SIGN_MESSAGE_LIB_CONTRACT_ADDRESS={{ safe_contracts.sign_message_lib }}
SIGN_MESSAGE_LIB_V1_4_1_CONTRACT_ADDRESS={{ safe_contracts.sign_message_lib }}
SIMULATE_TX_ACCESSOR_CONTRACT_ADDRESS={{ safe_contracts.simulate_tx_accessor }}
SIMULATE_TX_ACCESSOR_V1_4_1_CONTRACT_ADDRESS={{ safe_contracts.simulate_tx_accessor }}

# Indexing settings
ETH_EVENTS_BLOCK_PROCESS_LIMIT=1000
ETH_EVENTS_QUERY_CHUNK_SIZE=1000
ETH_INTERNAL_TXS_BLOCK_PROCESS_LIMIT=1000
ETH_INTERNAL_NO_FILTER=1
# Avalanche has instant finality (single-slot), no reorgs possible
ETH_REORG_BLOCKS=0

# Token settings
TOKENS_LOGO_BASE_URI=
TOKENS_LOGO_EXTENSION=.png

# AWS (not used, but required)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
