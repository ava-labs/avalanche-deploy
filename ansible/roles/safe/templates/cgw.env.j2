# Safe Client Gateway Configuration
# Generated by Ansible for chain {{ evm_chain_id }}

# Application settings
APPLICATION_PORT=3666
LOG_LEVEL=info

# Database
POSTGRES_HOST=postgres-cgw
POSTGRES_PORT=5432
POSTGRES_DB={{ safe_cgw_db_name }}
POSTGRES_USER={{ safe_db_user }}
POSTGRES_PASSWORD={{ safe_db_password }}

# Redis (all chains use same redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URI=redis://redis:6379
REDIS_URI_MAINNET=redis://redis:6379

# Service URLs
CONFIG_SERVICE_URI=http://cfg:8000
TRANSACTION_SERVICE_URI=http://txs-web:8888

# Chain-specific transaction service URLs
TRANSACTION_SERVICE_{{ evm_chain_id }}_URI=http://txs-web:8888

# Feature flags
FEATURE_FLAG_NESTED_DECODING=true
FEATURE_FLAG_BALANCES_RATE_IMPLEMENTATION=COINGECKO

# Rate limiting
THROTTLE_RATE=100
THROTTLE_TTL=60

# CORS
CORS_ALLOWED_ORIGINS=*

# Exchange rate API (optional)
EXCHANGE_API_BASE_URI=
EXCHANGE_API_KEY=

# Webhook authentication token (must match CGW_FLUSH_TOKEN in cfg.env)
AUTH_TOKEN={{ safe_webhook_token }}
