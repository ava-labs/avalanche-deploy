# Safe Client Gateway (Nest) Configuration
# Generated by Ansible for chain {{ evm_chain_id }}

# Application settings
APPLICATION_PORT=3000
LOG_LEVEL=info

# Environment mode (development avoids strict AWS/Blockaid validation)
CGW_ENV=development

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Service URLs
SAFE_CONFIG_BASE_URI=http://cfg:8000
SAFE_TRANSACTION_SERVICE_BASE_URI=http://txs-web:8888

# Chain-specific transaction service URL
TRANSACTION_SERVICE_{{ evm_chain_id }}_URI=http://txs-web:8888

# Webhook authentication token (must match CGW_FLUSH_TOKEN in cfg.env)
AUTH_TOKEN={{ safe_webhook_token }}

# Feature flags
FEATURES_NESTED_DECODING=true

# CORS
ACCESS_CONTROL_ALLOW_ORIGIN_LIST=*

# Database for CGW (required in v1.80+ for auth/spaces/users)
POSTGRES_HOST=postgres-cgw
POSTGRES_PORT=5432
POSTGRES_DB=safe_cgw
POSTGRES_USER={{ safe_db_user }}
POSTGRES_PASSWORD={{ safe_db_password }}
POSTGRES_SSL_ENABLED=false

# AMQP (RabbitMQ for event-driven cache hooks)
AMQP_URL=amqp://{{ safe_rabbitmq_user }}:{{ safe_rabbitmq_password }}@rabbitmq:5672

# JWT for auth sessions
JWT_ISSUER=safe-client-gateway
JWT_SECRET={{ safe_webhook_token }}

# Fingerprint encryption
FINGERPRINT_ENCRYPTION_KEY=00000000000000000000000000000000

# ----- Self-hosted placeholder values (not used but required by CGW at startup) -----

# Blocklist (OFAC/sanctions screening - not needed for private L1s)
BLOCKLIST_ENCRYPTED_DATA=disabled
BLOCKLIST_SECRET_KEY=00000000000000000000000000000000
BLOCKLIST_SECRET_SALT=00000000000000000000000000000000

# Email notifications (disabled for self-hosted)
EMAIL_API_APPLICATION_CODE=disabled
EMAIL_API_FROM_EMAIL=noreply@safe.localhost
EMAIL_API_KEY=disabled
EMAIL_TEMPLATE_RECOVERY_TX=disabled
EMAIL_TEMPLATE_UNKNOWN_RECOVERY_TX=disabled
EMAIL_TEMPLATE_VERIFICATION_CODE=disabled

# Infura (not needed - we have direct RPC)
INFURA_API_KEY=disabled

# Bridge API
BRIDGE_API_KEY=disabled

# Push notifications (disabled for self-hosted)
PUSH_NOTIFICATIONS_API_PROJECT=disabled
PUSH_NOTIFICATIONS_API_SERVICE_ACCOUNT_CLIENT_EMAIL=disabled@safe.localhost
PUSH_NOTIFICATIONS_API_SERVICE_ACCOUNT_PRIVATE_KEY=disabled

# Relay (gas-sponsored transactions) - disabled for self-hosted
# RELAY_THROTTLE_LIMIT=0 prevents the UI from offering relay-based Safe creation
RELAY_THROTTLE_LIMIT=0
RELAY_PROVIDER_API_KEY_OPTIMISM=disabled
RELAY_PROVIDER_API_KEY_BSC=disabled
RELAY_PROVIDER_API_KEY_GNOSIS_CHAIN=disabled
RELAY_PROVIDER_API_KEY_POLYGON=disabled
RELAY_PROVIDER_API_KEY_POLYGON_ZKEVM=disabled
RELAY_PROVIDER_API_KEY_BASE=disabled
RELAY_PROVIDER_API_KEY_ARBITRUM_ONE=disabled
RELAY_PROVIDER_API_KEY_AVALANCHE=disabled
RELAY_PROVIDER_API_KEY_LINEA=disabled
RELAY_PROVIDER_API_KEY_BLAST=disabled
RELAY_PROVIDER_API_KEY_UNICHAIN=disabled
RELAY_PROVIDER_API_KEY_SEPOLIA=disabled

# Staking (disabled for self-hosted)
STAKING_API_KEY=disabled
STAKING_TESTNET_API_KEY=disabled

# CSV Export - use local file storage (no AWS needed)
CSV_EXPORT_FILE_STORAGE_TYPE=local
CSV_AWS_ACCESS_KEY_ID=not-used
CSV_AWS_SECRET_ACCESS_KEY=not-used

# Targeted Messaging - use local file storage
TARGETED_MESSAGING_FILE_STORAGE_TYPE=local

# Base AWS keys (required by CloudStorageModule DI even with local storage)
AWS_ACCESS_KEY_ID=not-used
AWS_SECRET_ACCESS_KEY=not-used
