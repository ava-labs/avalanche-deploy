version: '3.8'

services:
  # PostgreSQL databases
  postgres-txs:
    image: postgres:14-alpine
    container_name: safe-postgres-txs
    environment:
      POSTGRES_DB: {{ safe_txs_db_name }}
      POSTGRES_USER: {{ safe_db_user }}
      POSTGRES_PASSWORD: {{ safe_db_password }}
    volumes:
      - {{ safe_data_dir }}/postgres-txs:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ safe_db_user }} -d {{ safe_txs_db_name }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  postgres-cfg:
    image: postgres:14-alpine
    container_name: safe-postgres-cfg
    environment:
      POSTGRES_DB: {{ safe_cfg_db_name }}
      POSTGRES_USER: {{ safe_db_user }}
      POSTGRES_PASSWORD: {{ safe_db_password }}
    volumes:
      - {{ safe_data_dir }}/postgres-cfg:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ safe_db_user }} -d {{ safe_cfg_db_name }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  postgres-cgw:
    image: postgres:14-alpine
    container_name: safe-postgres-cgw
    environment:
      POSTGRES_DB: safe_cgw
      POSTGRES_USER: {{ safe_db_user }}
      POSTGRES_PASSWORD: {{ safe_db_password }}
    volumes:
      - {{ safe_data_dir }}/postgres-cgw:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ safe_db_user }} -d safe_cgw"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  # Redis cache
  redis:
    image: redis:7-alpine
    container_name: safe-redis
    command: redis-server --appendonly yes
    volumes:
      - {{ safe_data_dir }}/redis:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  # RabbitMQ message queue
  rabbitmq:
    image: rabbitmq:3-management-alpine
    container_name: safe-rabbitmq
    environment:
      RABBITMQ_DEFAULT_USER: {{ safe_rabbitmq_user }}
      RABBITMQ_DEFAULT_PASS: {{ safe_rabbitmq_password }}
    volumes:
      - {{ safe_data_dir }}/rabbitmq:/var/lib/rabbitmq
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "-q", "ping"]
      interval: 30s
      timeout: 30s
      retries: 3
    restart: unless-stopped

  # Transaction Service - Web
  txs-web:
    image: safeglobal/safe-transaction-service:{{ safe_txs_version }}@{{ safe_txs_digest }}
    container_name: safe-txs-web
    env_file:
      - {{ safe_install_dir }}/txs.env
    depends_on:
      postgres-txs:
        condition: service_healthy
      redis:
        condition: service_healthy
      rabbitmq:
        condition: service_healthy
    volumes:
      - {{ safe_install_dir }}/init:/init:ro
      - {{ safe_install_dir }}/patches/safe_events_indexer.py:/app/safe_transaction_service/history/indexers/safe_events_indexer.py:ro
    ports:
      - "{{ safe_txs_port }}:8888"
    command: docker/web/run_web.sh
    extra_hosts:
      - "host.docker.internal:host-gateway"
    restart: unless-stopped

  # Transaction Service - Worker: indexing
  txs-worker-indexer:
    image: safeglobal/safe-transaction-service:{{ safe_txs_version }}@{{ safe_txs_digest }}
    container_name: safe-txs-worker-indexer
    env_file:
      - {{ safe_install_dir }}/txs.env
    environment:
      WORKER_QUEUES: default,indexing,processing
    depends_on:
      - txs-web
    volumes:
      - {{ safe_install_dir }}/patches/safe_events_indexer.py:/app/safe_transaction_service/history/indexers/safe_events_indexer.py:ro
    command: docker/web/celery/worker/run.sh
    extra_hosts:
      - "host.docker.internal:host-gateway"
    restart: unless-stopped

  # Transaction Service - Worker: contracts & tokens
  txs-worker-contracts-tokens:
    image: safeglobal/safe-transaction-service:{{ safe_txs_version }}@{{ safe_txs_digest }}
    container_name: safe-txs-worker-contracts-tokens
    env_file:
      - {{ safe_install_dir }}/txs.env
    environment:
      WORKER_QUEUES: contracts,tokens
    depends_on:
      - txs-web
    command: docker/web/celery/worker/run.sh
    extra_hosts:
      - "host.docker.internal:host-gateway"
    restart: unless-stopped

  # Transaction Service - Worker: notifications & webhooks
  txs-worker-notifications:
    image: safeglobal/safe-transaction-service:{{ safe_txs_version }}@{{ safe_txs_digest }}
    container_name: safe-txs-worker-notifications
    env_file:
      - {{ safe_install_dir }}/txs.env
    environment:
      WORKER_QUEUES: notifications,webhooks
    depends_on:
      - txs-web
    command: docker/web/celery/worker/run.sh
    extra_hosts:
      - "host.docker.internal:host-gateway"
    restart: unless-stopped

  # Transaction Service - Scheduler (Celery Beat)
  txs-scheduler:
    image: safeglobal/safe-transaction-service:{{ safe_txs_version }}@{{ safe_txs_digest }}
    container_name: safe-txs-scheduler
    env_file:
      - {{ safe_install_dir }}/txs.env
    depends_on:
      - txs-web
    volumes:
      - {{ safe_install_dir }}/patches/safe_events_indexer.py:/app/safe_transaction_service/history/indexers/safe_events_indexer.py:ro
    command: docker/web/celery/scheduler/run.sh
    extra_hosts:
      - "host.docker.internal:host-gateway"
    restart: unless-stopped

  # Config Service
  cfg:
    image: safeglobal/safe-config-service:{{ safe_cfg_version }}@{{ safe_cfg_digest }}
    container_name: safe-cfg
    env_file:
      - {{ safe_install_dir }}/cfg.env
    depends_on:
      postgres-cfg:
        condition: service_healthy
    volumes:
      - {{ safe_install_dir }}/init:/init:ro
    ports:
      - "{{ safe_cfg_port }}:8000"
    command: docker/web/run_web.sh
    restart: unless-stopped

  # Client Gateway (nest)
  cgw:
    image: {{ safe_cgw_image }}:{{ safe_cgw_version }}@{{ safe_cgw_digest }}
    container_name: safe-cgw
    env_file:
      - {{ safe_install_dir }}/cgw.env
    depends_on:
      redis:
        condition: service_healthy
      postgres-cgw:
        condition: service_healthy
      rabbitmq:
        condition: service_healthy
      txs-web:
        condition: service_started
      cfg:
        condition: service_started
    ports:
      - "{{ safe_cgw_port }}:3000"
    restart: unless-stopped

  # Safe Wallet Web UI (patched for custom chain ID)
  ui:
    image: safe-ui-patched:{{ evm_chain_id }}
    container_name: safe-ui
    depends_on:
      - cgw
    ports:
      - "{{ safe_ui_port }}:8080"
    restart: unless-stopped

networks:
  default:
    name: safe-network
