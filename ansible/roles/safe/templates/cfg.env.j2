# Safe Config Service Configuration
# Generated by Ansible for chain {{ evm_chain_id }}

# Django settings
SECRET_KEY={{ safe_cfg_secret_key }}
DEBUG=0
ROOT_LOG_LEVEL=INFO
DJANGO_ALLOWED_HOSTS=*
{% set safe_host = safe_domain if safe_domain else ansible_host %}
CSRF_TRUSTED_ORIGINS=https://{{ safe_host }},https://{{ ansible_host }},http://{{ ansible_host }}:{{ safe_http_port }},http://localhost:{{ safe_http_port }}

# Database - Config Service uses POSTGRES_* variables
POSTGRES_USER={{ safe_db_user }}
POSTGRES_PASSWORD={{ safe_db_password }}
POSTGRES_NAME={{ safe_cfg_db_name }}
POSTGRES_HOST=postgres-cfg
POSTGRES_PORT=5432

# Gunicorn settings (required by entrypoint)
GUNICORN_BIND_SOCKET=unix:/nginx/gunicorn.socket
GUNICORN_BIND_PORT=8000
DOCKER_NGINX_VOLUME_ROOT=/nginx

# Chain configuration will be added via Django admin
CGW_URL=http://cgw:3000
CGW_FLUSH_TOKEN={{ safe_webhook_token }}
CGW_AUTH_TOKEN={{ safe_webhook_token }}
