[Unit]
Description=ICM Relayer - Avalanche Cross-Chain Message Relay
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/icm-relayer
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
User=icmrelayer
Group=icmrelayer

[Install]
WantedBy=multi-user.target
