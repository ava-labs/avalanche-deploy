{# ICM Relayer Configuration - Generated by Ansible #}
{
  "log-level": "{{ icm_relayer_log_level | default('info') }}",
  "p-chain-api": {
    "base-url": "http://{{ icm_relayer_rpc_host | default('127.0.0.1') }}:9650"
  },
  "info-api": {
    "base-url": "http://{{ icm_relayer_rpc_host | default('127.0.0.1') }}:9650"
  },
  "storage-location": "{{ icm_relayer_storage_location | default('/data/icm-relayer-storage') }}",
  "process-missed-blocks": {{ icm_relayer_process_missed_blocks | default(true) | to_json }},
  "api-port": {{ icm_relayer_api_port | default(8080) }},
  "metrics-port": {{ icm_relayer_metrics_port | default(9090) }},
  "source-blockchains": [
    {
      "subnet-id": "{{ icm_relayer_source_subnet_id }}",
      "blockchain-id": "{{ icm_relayer_source_blockchain_id }}",
      "vm": "evm",
      "rpc-endpoint": {
        "base-url": "http://{{ icm_relayer_rpc_host | default('127.0.0.1') }}:9650/ext/bc/{{ icm_relayer_source_blockchain_id }}/rpc"
      },
      "ws-endpoint": {
        "base-url": "ws://{{ icm_relayer_rpc_host | default('127.0.0.1') }}:9650/ext/bc/{{ icm_relayer_source_blockchain_id }}/ws"
      },
      "message-contracts": {
{% for addr, config in (icm_relayer_message_contracts | default({'0x0000000000000000000000000000000000000000': {'message_format': 'off-chain-registry'}})).items() %}
        "{{ addr }}": {
          "message-format": "{{ config.message_format }}"
        }{{ '' if loop.last else ',' }}
{% endfor %}
      }
    }
{% if icm_relayer_bidirectional | default(true) %}
    ,{
      "subnet-id": "{{ icm_relayer_cchain_ids[icm_relayer_network | default('fuji')].subnet_id }}",
      "blockchain-id": "{{ icm_relayer_cchain_ids[icm_relayer_network | default('fuji')].blockchain_id }}",
      "vm": "evm",
      "rpc-endpoint": {
        "base-url": "http://{{ icm_relayer_rpc_host | default('127.0.0.1') }}:9650/ext/bc/C/rpc"
      },
      "ws-endpoint": {
        "base-url": "ws://{{ icm_relayer_rpc_host | default('127.0.0.1') }}:9650/ext/bc/C/ws"
      },
      "message-contracts": {
        "0x0000000000000000000000000000000000000000": {
          "message-format": "off-chain-registry"
        }
      }
    }
{% endif %}
{% for src in icm_relayer_extra_source_blockchains | default([]) %}
    ,{{ src | to_nice_json }}
{% endfor %}
  ],
  "destination-blockchains": [
    {
      "subnet-id": "{{ icm_relayer_cchain_ids[icm_relayer_network | default('fuji')].subnet_id }}",
      "blockchain-id": "{{ icm_relayer_cchain_ids[icm_relayer_network | default('fuji')].blockchain_id }}",
      "vm": "evm",
      "rpc-endpoint": {
        "base-url": "http://{{ icm_relayer_rpc_host | default('127.0.0.1') }}:9650/ext/bc/C/rpc"
      },
      "account-private-key": "{{ icm_relayer_destination_private_key }}"
    },
    {
      "subnet-id": "{{ icm_relayer_source_subnet_id }}",
      "blockchain-id": "{{ icm_relayer_source_blockchain_id }}",
      "vm": "evm",
      "rpc-endpoint": {
        "base-url": "http://{{ icm_relayer_rpc_host | default('127.0.0.1') }}:9650/ext/bc/{{ icm_relayer_source_blockchain_id }}/rpc"
      },
      "account-private-key": "{{ icm_relayer_destination_private_key }}"
    }
{% for dst in icm_relayer_extra_destination_blockchains | default([]) %}
    ,{{ dst | to_nice_json }}
{% endfor %}
  ]
}
