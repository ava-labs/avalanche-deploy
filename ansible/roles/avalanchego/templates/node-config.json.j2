{
    "network-id": "{{ avalanchego_network_ids[avalanchego_network] }}",
    "http-host": "0.0.0.0",
    "http-port": {{ avalanchego_http_port }},
    "staking-port": {{ avalanchego_staking_port }},
    "http-allowed-hosts": "*",
    "api-admin-enabled": {{ avalanchego_api_admin_enabled | lower }},
    "api-info-enabled": {{ avalanchego_api_info_enabled | lower }},
    "api-health-enabled": {{ avalanchego_api_health_enabled | lower }},
    "index-enabled": {{ avalanchego_index_enabled | lower }},
    "log-level": "{{ avalanchego_log_level }}",
    "log-display-level": "{{ avalanchego_log_display_level }}",
    "log-dir": "{{ avalanchego_log_dir }}",
    "db-dir": "{{ avalanchego_data_dir }}/db",
    "plugin-dir": "{{ avalanchego_plugin_dir }}",
    "chain-config-dir": "{{ avalanchego_config_dir }}/chains",
    "partial-sync-primary-network": {{ avalanchego_partial_sync_primary_network | default(true) | lower }}{% if track_subnets is defined and track_subnets | length > 0 %},
    "track-subnets": "{{ track_subnets | join(',') }}"{% endif %}{% if l1_bootstrap_ids is defined and l1_bootstrap_ids | length > 0 %},
    "bootstrap-ids": "{{ l1_bootstrap_ids | join(',') }}",
    "bootstrap-ips": "{{ l1_bootstrap_ips | join(',') }}"{% endif %}
}
