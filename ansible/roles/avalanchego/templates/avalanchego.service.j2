[Unit]
Description=Avalanche Node
Documentation=https://docs.avax.network
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ avalanchego_user }}
Group={{ avalanchego_group }}
Environment="HOME=/home/{{ avalanchego_user }}"
ExecStart=/usr/local/bin/avalanchego --config-file={{ avalanchego_config_dir }}/node.json
Restart=always
RestartSec=5
LimitNOFILE=65535
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
