# Blockscout Frontend Environment Configuration
# Auto-generated by Ansible

# App host (required)
NEXT_PUBLIC_APP_HOST={{ ansible_host }}

# API endpoints - backend is accessible at backend:4000 inside docker network
NEXT_PUBLIC_API_HOST=backend
NEXT_PUBLIC_API_PORT=4000
NEXT_PUBLIC_API_PROTOCOL=http
NEXT_PUBLIC_API_WEBSOCKET_PROTOCOL=ws

# Network info
NEXT_PUBLIC_NETWORK_NAME={{ blockscout_network_name }}
NEXT_PUBLIC_NETWORK_SHORT_NAME={{ blockscout_network_short_name }}
# NEXT_PUBLIC_NETWORK_ID must be the numeric EVM chain ID (not the Avalanche chain ID string)
NEXT_PUBLIC_NETWORK_ID={{ blockscout_evm_chain_id }}
NEXT_PUBLIC_NETWORK_CURRENCY_NAME={{ blockscout_coin_name }}
NEXT_PUBLIC_NETWORK_CURRENCY_SYMBOL={{ blockscout_coin_symbol }}
NEXT_PUBLIC_NETWORK_CURRENCY_DECIMALS=18

# RPC for wallet connection
NEXT_PUBLIC_NETWORK_RPC_URL={{ blockscout_rpc_url }}

# Branding
{% if blockscout_network_logo_url %}
NEXT_PUBLIC_NETWORK_LOGO={{ blockscout_network_logo_url }}
{% endif %}
{% if blockscout_network_icon_url %}
NEXT_PUBLIC_NETWORK_ICON={{ blockscout_network_icon_url }}
{% endif %}

# Features
NEXT_PUBLIC_IS_TESTNET=true
NEXT_PUBLIC_API_SPEC_URL=https://raw.githubusercontent.com/blockscout/blockscout-api-v2-swagger/main/swagger.yaml

# Stats - browser needs public IP, not internal Docker hostname
# Stats service is exposed on port 8050
NEXT_PUBLIC_STATS_API_HOST=http://{{ ansible_host }}:8050

# Visualizer and contract verification use internal services (not browser-accessible by default)
# These are disabled in NEXT_PUBLIC_HOMEPAGE_CHARTS to avoid browser errors
# To enable, expose these services on host ports and update the URLs below
# NEXT_PUBLIC_VISUALIZE_API_HOST=http://{{ ansible_host }}:8151
# NEXT_PUBLIC_CONTRACT_INFO_API_HOST=http://{{ ansible_host }}:8150

# Homepage
NEXT_PUBLIC_HOMEPAGE_CHARTS=['daily_txs']

# Footer
NEXT_PUBLIC_FOOTER_LINKS=[]

# Ad configuration (disabled)
NEXT_PUBLIC_AD_BANNER_PROVIDER=none
NEXT_PUBLIC_AD_TEXT_PROVIDER=none
