# Blockscout Backend Environment Configuration
# Auto-generated by Ansible

# Database
DATABASE_URL=postgresql://{{ blockscout_db_user }}:{{ blockscout_db_password }}@db:5432/{{ blockscout_db_name }}
SECRET_KEY_BASE={{ blockscout_secret_key_base }}

# Ethereum JSON RPC
ETHEREUM_JSONRPC_VARIANT=geth
ETHEREUM_JSONRPC_HTTP_URL={{ blockscout_rpc_url }}
{% if blockscout_ws_url %}
ETHEREUM_JSONRPC_WS_URL={{ blockscout_ws_url }}
{% endif %}
{% if blockscout_trace_url %}
ETHEREUM_JSONRPC_TRACE_URL={{ blockscout_trace_url }}
{% else %}
ETHEREUM_JSONRPC_TRACE_URL={{ blockscout_rpc_url }}
{% endif %}

# Network configuration
NETWORK={{ blockscout_network_name }}
SUBNETWORK={{ blockscout_network_short_name }}
CHAIN_ID={{ blockscout_chain_id }}
COIN={{ blockscout_coin_symbol }}
COIN_NAME={{ blockscout_coin_name }}

# Branding
{% if blockscout_network_logo_url %}
LOGO={{ blockscout_network_logo_url }}
{% endif %}
{% if blockscout_network_icon_url %}
LOGO_FOOTER={{ blockscout_network_icon_url }}
{% endif %}

# Server
PORT=4000
POOL_SIZE=50
ECTO_USE_SSL=false

# Indexer configuration
INDEXER_DISABLE_PENDING_TRANSACTIONS_FETCHER={{ blockscout_indexer_disable_pending_txs | lower }}
INDEXER_DISABLE_INTERNAL_TRANSACTIONS_FETCHER={{ blockscout_indexer_disable_internal_txs | lower }}
BLOCK_TRANSFORMER={{ blockscout_block_transformer }}

# Features
DISABLE_EXCHANGE_RATES={{ blockscout_disable_exchange_rates | lower }}
DISABLE_WRITE_API={{ blockscout_disable_write_methods | lower }}
DISABLE_INDEXER=false
DISABLE_REALTIME_INDEXER=false
ENABLE_TXS_STATS=true

{% if blockscout_enable_smart_contract_verification %}
# Smart Contract Verification
MICROSERVICE_SC_VERIFIER_ENABLED=true
MICROSERVICE_SC_VERIFIER_URL=http://smart-contract-verifier:8050
{% if blockscout_enable_sourcify %}
SOURCIFY_INTEGRATION_ENABLED=true
SOURCIFY_SERVER_URL=https://sourcify.dev/server
SOURCIFY_REPO_URL=https://repo.sourcify.dev/contracts
{% endif %}
{% endif %}

# API rate limiting
# Disabled by default for private L1 deployments - frontend makes many API calls
API_RATE_LIMIT_DISABLED=true
API_RATE_LIMIT={{ blockscout_api_rate_limit }}
API_RATE_LIMIT_BY_IP={{ blockscout_api_rate_limit_by_ip | lower }}

# Redis for caching
CACHE_ADDRESS_TOKEN_TRANSFERS_COUNTER_PERIOD=1h
CACHE_ADDRESS_TRANSACTIONS_COUNTER_PERIOD=1h
ACCOUNT_ENABLED=false

# External services
{% if blockscout_coingecko_api_key %}
COINGECKO_API_KEY={{ blockscout_coingecko_api_key }}
{% endif %}

# Misc
SHOW_TESTNET_LABEL=true
TESTNET_LABEL_TEXT={{ blockscout_network_short_name }}
HEALTHY_BLOCKS_PERIOD=60
HISTORY_FETCH_INTERVAL=30
TXS_HISTORIAN_INIT_LAG=0
TXS_STATS_DAYS_TO_COMPILE_AT_INIT=10

# Logging
LOG_LEVEL=info
